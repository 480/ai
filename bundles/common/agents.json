{
  "bundle_version": 1,
  "targets": [
    "opencode",
    "claude",
    "codex"
  ],
  "roles": [
    {
      "id": "480-architect",
      "display_name": "480-architect",
      "description": "Architects whole implementations.",
      "role": "planning, scoping, and orchestrating the implementation/review loop",
      "mode": "primary",
      "model": "openai/gpt-5.4",
      "reasoning": "xhigh",
      "instruction_source": "bundles/common/instructions/480-architect.md",
      "target_metadata": {
        "opencode": {
          "temperature": 0.1,
          "tools": {
            "write": true,
            "edit": true,
            "bash": true
          }
        },
        "claude": {
          "name": "480-architect",
          "instruction_source": "providers/claude/instructions/480-architect.md",
          "tools": [
            "Agent(480-developer, 480-code-reviewer, 480-code-reviewer2, 480-code-scanner)",
            "Read",
            "Write",
            "Edit",
            "Glob",
            "Grep",
            "Bash",
            "WebFetch"
          ]
        },
        "codex": {
          "name": "480",
          "instruction_source": "providers/codex/instructions/480-architect.md",
          "sandbox_mode": "workspace-write"
        }
      }
    },
    {
